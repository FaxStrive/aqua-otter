# Aqua Otter — environment variables
# Copy to .env.local and fill in real values.

# GHL Contacts API — every lead capture point (homepage form, exit-intent
# guide, free water test, quiz, service page, city page) POSTs directly to
# the GHL Contacts API. Existing contacts (same email/phone) are upserted
# with refreshed tags + custom fields.
GHL_API_KEY=
GHL_LOCATION_ID=

# Anthropic API key — no longer used since we removed the custom
# "Ask the Otter" chat in favor of the GHL-hosted AI chat widget.
# Leave commented unless you re-introduce the custom chat.
# ANTHROPIC_API_KEY=

# Optional: Resend API key for lead emails.
# RESEND_API_KEY=

# Google Places API for live reviews feed (reviews page auto-refreshes daily).
# 1. Find your Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id
# 2. Enable "Places API" in Google Cloud Console, create a key.
GOOGLE_PLACE_ID=
GOOGLE_PLACES_API_KEY=
